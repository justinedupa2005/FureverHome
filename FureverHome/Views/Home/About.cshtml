@{
    ViewData["Title"] = "About Us";
}

<!-- MAIN CONTAINER WITH GRADIENT BACKGROUND -->
<div class="min-h-screen bg-gradient-to-r from-[#d4ecd2] via-[#eef4e6] to-[#d4ecd2]">

    <!-- ABOUT SECTION -->
    <section class="max-w-7xl mx-auto px-6 py-24">

        <div class="grid lg:grid-cols-2 gap-16 items-center">

            <!-- IMAGE -->
            <div class="flex justify-center lg:justify-start">
                <div class="w-full max-w-[500px] rounded-2xl overflow-hidden shadow-lg border-8 border-white">
                    <img src="https://images.unsplash.com/photo-1517849845537-4d257902454a?q=80&w=1200&auto=format&fit=crop"
                         alt="Woman holding cat"
                         class="w-full h-full object-cover" />
                </div>
            </div>

            <!-- CONTENT -->
            <div>

                <!-- TITLE -->
                <h2 class="text-5xl lg:text-6xl font-extrabold leading-tight text-[#111111]">
                    About
                    <span class="text-[#f28a2e]">
                        Furever Home
                    </span>
                </h2>

                <!-- DESCRIPTION -->
                <div class="mt-10 space-y-8">

                    <p class="text-[#5a7a58] text-2xl leading-relaxed font-semibold">
                        We are a community-driven platform dedicated to connecting loving
                        families with pets in need of a forever home. Every animal deserves
                        warmth, care, and unconditional love.
                    </p>

                    <p class="text-[#5a7a58] text-2xl leading-relaxed font-semibold">
                        Our platform makes it easy for individuals and rescuers to list pets,
                        and for families to find their perfect companion all without
                        complicated processes.
                    </p>

                </div>

                <!-- BUTTON -->
                <div class="mt-12">
                    <button class="bg-[#2f7b2f] hover:bg-green-800 transition text-white px-12 py-4 rounded-full text-lg font-semibold shadow-lg">
                        Join Our Community
                    </button>
                </div>

            </div>

        </div>

    </section>

</div>