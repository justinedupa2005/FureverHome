<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Furever Home</title>

    <!-- Tailwind CSS CDN (Global) -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Google Font (Global) -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
        }
    </style>
</head>
<body class="bg-[#dfe8dd]">

    <!-- NAVBAR -->
    <nav class="max-w-7xl mx-auto px-6 pt-6">
        <div class="bg-white rounded-full px-8 py-4 flex items-center justify-between shadow-sm">

            <!-- Logo -->
            <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-green-100 flex items-center justify-center">
                    <span class="text-green-700 font-bold">♡</span>
                </div>

                <h1 class="font-semibold text-[15px] text-[#1d1d1d]">
                    Furever Home
                </h1>
            </div>

            <!-- Menu -->
            <div class="hidden md:flex items-center gap-10 text-[13px] font-medium text-[#1d1d1d]">
                <a href="#" class="hover:text-green-700 transition">Home</a>
                <a href="#" class="hover:text-green-700 transition">About Us</a>
                <a href="#" class="hover:text-green-700 transition">Contact</a>
            </div>

            <!-- Buttons -->
            <div class="flex items-center gap-3">
                <button class="px-6 py-2 rounded-full border border-green-700 text-green-700 text-sm font-medium hover:bg-green-50 transition">
                    Login
                </button>

                <button class="px-6 py-2 rounded-full bg-[#f28a2e] text-white text-sm font-medium hover:bg-orange-500 transition">
                    Sign Up
                </button>
            </div>

        </div>
    </nav>

    <!-- UNIQUE PAGE CONTENT INJECTED HERE -->
    <main role="main">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="bg-[#2f6f2f] text-white py-8">

        <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-5">

            <!-- Left -->
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-green-100 text-[#2f6f2f] flex items-center justify-center font-bold">
                    ♡
                </div>

                <span class="font-semibold">
                    Furever Home
                </span>
            </div>

            <!-- Center -->
            <p class="text-sm text-green-100">
                2025 Furever Home. Made with love for every paw.
            </p>

            <!-- Right -->
            <div class="flex items-center gap-6 text-sm">
                <a href="#" class="hover:text-green-200 transition">Home</a>
                <a href="#" class="hover:text-green-200 transition">About</a>
                <a href="#" class="hover:text-green-200 transition">Contact</a>
            </div>

        </div>

    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>