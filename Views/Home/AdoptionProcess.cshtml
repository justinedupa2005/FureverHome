@{
    ViewData["Title"] = "Adoption Process";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="py-lg bg-white">
    <div class="container">
        <div class="section-header">
            <span class="section-eyebrow">Step by Step</span>
            <h2 class="section-title">The <span class="highlight">Adoption Process</span></h2>
            <p class="section-subtitle">Follow these simple steps to welcome a furry friend into your home.</p>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; margin-top: 60px;">
            <div class="card" style="padding: 40px; text-align: center;">
                <div style="font-size: 3rem; margin-bottom: 20px;">📋</div>
                <h3>1. Create Account</h3>
                <p>Sign up and complete your profile so we can get to know you better.</p>
            </div>
            <div class="card" style="padding: 40px; text-align: center;">
                <div style="font-size: 3rem; margin-bottom: 20px;">🔎</div>
                <h3>2. Browse Listings</h3>
                <p>Use our smart filters to find pets that match your lifestyle and home.</p>
            </div>
            <div class="card" style="padding: 40px; text-align: center;">
                <div style="font-size: 3rem; margin-bottom: 20px;">💛</div>
                <h3>3. Apply & Meet</h3>
                <p>Contact the owner, ask questions, and schedule a meet-and-greet.</p>
            </div>
            <div class="card" style="padding: 40px; text-align: center;">
                <div style="font-size: 3rem; margin-bottom: 20px;">🏡</div>
                <h3>4. Welcome Home</h3>
                <p>Finalize the details and welcome your new furever companion home!</p>
            </div>
        </div>
    </div>
</div>
