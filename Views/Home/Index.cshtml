@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="/css/home.css" />
}

<!-- ===== HERO SECTION ===== -->
<section class="hero" style="background-image: url('/images/background_home_page.png'); background-size: cover; background-position: center;">
    <div class="container">
        <div class="hero-inner">
            <!-- LEFT: text -->
            <div class="hero-text">
                <p class="section-eyebrow">Find your perfect companion</p>
                <h1>Where every <span class="highlight">paw</span><br>finds its furever home.</h1>
                <p>Connect loving families with pets that need a forever home. Browse hundreds of adoptable animals and give a pet a second chance.</p>
                <div class="hero-btns">
                    <a href="/Pets" class="btn btn-orange btn-lg">Browse Pets 🐾</a>
                    @if (User.Identity?.IsAuthenticated != true)
                    {
                        <a href="/Account/Register" class="btn btn-white btn-lg">Get Started</a>
                    }
                    else
                    {
                        <a href="/Dashboard" class="btn btn-white btn-lg">My Dashboard</a>
                    }
                </div>
            </div>
            <!-- RIGHT: image area -->
            <div class="hero-image">
                @if (User.Identity?.IsAuthenticated != true)
                {
                    <!-- Only show phone if logged out -->
                    <img src="/images/phone_login.png" 
                         alt="Furever Home App" 
                         class="hero-phone-img">
                }

                <!-- Mascot logic -->
                <div class="mascot-hero @(User.Identity?.IsAuthenticated == true ? "mascot-logged-in" : "")">
                    <img src="/images/illustration_home.png" alt="Mascot Cat" style="width: 100%; mix-blend-mode: multiply;">
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== STATS BANNER ===== -->
<section class="stats-banner">
    <div class="container">
        <div class="stats-grid">
            <div>
                <div class="stat-number">10</div>
                <div class="stat-label">Pets Listed</div>
            </div>
            <div>
                <div class="stat-number">200+</div>
                <div class="stat-label">Happy Adoptions</div>
            </div>
            <div>
                <div class="stat-number">50+</div>
                <div class="stat-label">Rescue Partners</div>
            </div>
        </div>
    </div>
</section>

<!-- Rest of the sections (How it works, Featured Pets, etc.) remain the same... -->
<section class="how-it-works">
    <div class="container">
        <div class="section-header">
            <span class="section-eyebrow">How It Works</span>
            <h2 class="section-title">Finding your perfect pet companion<br>is easy with <span class="highlight">Furever Home.</span></h2>
        </div>

        <div class="how-steps">
            <div class="how-step">
                <div class="how-step-icon">🔍</div>
                <h3>Browse Listings</h3>
                <p>Explore hundreds of pets looking for their forever home using our smart filters.</p>
            </div>
            <div class="how-step">
                <div class="how-step-icon">💚</div>
                <h3>Find Your Match</h3>
                <p>Browse and find the pet that perfectly matches your lifestyle and personality.</p>
            </div>
            <div class="how-step">
                <div class="how-step-icon">📞</div>
                <h3>Contact Us</h3>
                <p>Get in touch with the pet owner or rescue partner to learn more about the pet.</p>
            </div>
            <div class="how-step">
                <div class="how-step-icon">🏠</div>
                <h3>Bring Them Home</h3>
                <p>Complete the adoption process and welcome your new family member home.</p>
            </div>
        </div>
    </div>
</section>

<section class="featured-pets" style="padding: 100px 0; background-color: var(--cream); position: relative; overflow: hidden;">
    <div class="container">
        <div class="section-header" style="max-width: 700px; margin: 0 auto 60px; text-align: center;">
            <span class="section-eyebrow">Handpicked for you</span>
            <h2 class="section-title" style="font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 20px;">Pets Looking for a <span class="highlight">Home</span></h2>
            <p class="section-subtitle" style="font-size: 1.1rem; color: var(--text-muted); line-height: 1.7;">These adorable pets are waiting for someone just like you to give them a loving home. Start your furever journey today.</p>
        </div>

        <div class="pets-grid">
            <div class="pet-listing-card">
                <div class="pet-img-wrap">
                    <div class="pet-img-placeholder">🐶</div>
                    <span class="pet-status-badge available">Available</span>
                    <button class="pet-save-btn" title="Save to favorites">❤</button>
                </div>
                <div class="pet-listing-body">
                    <div class="pet-listing-name">Buddy</div>
                    <div class="pet-listing-meta">
                        <span class="meta-chip">🐕 Labrador</span>
                        <span class="meta-chip">📅 3 yrs</span>
                        <span class="meta-chip">♂ Male</span>
                    </div>
                    <div class="pet-location">📍 Guadalupe, Cebu City</div>
                    <div class="pet-listing-actions">
                        <a href="/Pets/Details/1" class="btn btn-green btn-sm">Learn More</a>
                    </div>
                </div>
            </div>

            <div class="pet-listing-card">
                <div class="pet-img-wrap">
                    <div class="pet-img-placeholder">🐱</div>
                    <span class="pet-status-badge available">Available</span>
                    <button class="pet-save-btn" title="Save to favorites">❤</button>
                </div>
                <div class="pet-listing-body">
                    <div class="pet-listing-name">Mochi</div>
                    <div class="pet-listing-meta">
                        <span class="meta-chip">🐈 Shorthair</span>
                        <span class="meta-chip">📅 2 yrs</span>
                        <span class="meta-chip">♀ Female</span>
                    </div>
                    <div class="pet-location">📍 Talamban, Cebu City</div>
                    <div class="pet-listing-actions">
                        <a href="/Pets/Details/2" class="btn btn-green btn-sm">Learn More</a>
                    </div>
                </div>
            </div>

            <div class="pet-listing-card">
                <div class="pet-img-wrap">
                    <div class="pet-img-placeholder">🐰</div>
                    <span class="pet-status-badge pending">Pending</span>
                    <button class="pet-save-btn" title="Save to favorites">❤</button>
                </div>
                <div class="pet-listing-body">
                    <div class="pet-listing-name">Kiwi</div>
                    <div class="pet-listing-meta">
                        <span class="meta-chip">🐇 Rabbit</span>
                        <span class="meta-chip">📅 1 yr</span>
                        <span class="meta-chip">♂ Male</span>
                    </div>
                    <div class="pet-location">📍 Mandaue, Cebu</div>
                    <div class="pet-listing-actions">
                        <a href="/Pets/Details/3" class="btn btn-green btn-sm">Learn More</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="view-all-wrap" style="text-align: center; margin-top: 60px;">
            <a href="/Pets" class="btn btn-green btn-lg" style="box-shadow: 0 10px 20px rgba(47, 106, 53, 0.15);">View All Pets 🐾</a>
        </div>
    </div>
</section>

<section class="adoption-process">
    <div class="container">
        <div class="section-header">
            <span class="section-eyebrow">Step by Step</span>
            <h2 class="section-title">The <span class="highlight">Adoption Process</span></h2>
            <p class="section-subtitle">Follow these simple steps to welcome a furry friend into your home.</p>
        </div>
        <div class="process-grid">
            <div class="process-card"><span class="process-card-icon">📋</span><h3>Create an Account</h3><p>Sign up for free and create your adopter profile.</p></div>
            <div class="process-card"><span class="process-card-icon">🔎</span><h3>Browse Listings</h3><p>Explore our curated listings of dogs and cats.</p></div>
            <div class="process-card"><span class="process-card-icon">💛</span><h3>Fall In Love</h3><p>Find the pet that speaks to your heart.</p></div>
            <div class="process-card"><span class="process-card-icon">📞</span><h3>Contact My Lister</h3><p>Connect directly with the rescue partner.</p></div>
            <div class="process-card"><span class="process-card-icon">🐾</span><h3>Meet & Greet</h3><p>Visit your chosen pet and make sure it's the right match.</p></div>
            <div class="process-card"><span class="process-card-icon">🏡</span><h3>Welcome New Home</h3><p>Complete paperwork and bring your friend home.</p></div>
        </div>
    </div>
</section>

<section class="about-section">
    <div class="container">
        <div class="about-inner">
            <div class="about-img-wrap">
                <img src="/images/about_photo.png" alt="About Furever Home" style="width: 100%; height: 100%; object-fit: cover; border-radius: 25px;" />
            </div>
            <div class="about-content">
                <div class="section-header">
                    <span class="section-eyebrow">About Furever Home</span>
                    <h2 class="section-title">About <span class="highlight">Furever Home</span></h2>
                </div>
                <p class="about-text">Furever Home is a community-driven platform dedicated to connecting families with pets.</p>
                <a href="/Home/About" class="btn btn-green btn-lg">Join Our Mission</a>
            </div>
        </div>
    </div>
</section>

<section class="contact-section">
    <div class="container">
        <div class="section-header">
            <span class="section-eyebrow">Get In Touch</span>
            <h2 class="section-title">Contact <span class="highlight">Us</span></h2>
        </div>
        <div class="contact-grid">
            <div class="contact-card"><div class="contact-card-icon">📞</div><h3>Call Us</h3><p>+63 947 123 4567</p></div>
            <div class="contact-card"><div class="contact-card-icon">✉️</div><h3>Email Us</h3><p>hello@fureverhome.ph</p></div>
            <div class="contact-card"><div class="contact-card-icon">📍</div><h3>Find Us</h3><p>Cebu City, Philippines</p></div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.querySelectorAll('.pet-save-btn').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                this.classList.toggle('active');
                this.innerHTML = this.classList.contains('active') ? '❤️' : '❤';
            });
        });
    </script>
}