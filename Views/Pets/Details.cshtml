@model FureverHome.Models.Pet
@{
    ViewData["Title"] = Model.PetName + " - Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="/css/pets.css" />
}

<div class="pet-details-page">
    <div class="container">

        <!-- Breadcrumb -->
        <nav style="margin-bottom:24px; font-size:0.88rem; color:var(--text-muted);">
            <a href="/" style="color:var(--green-primary)">Home</a>
            <span style="margin:0 8px;">›</span>
            <a href="/Pets" style="color:var(--green-primary)">Pets</a>
            <span style="margin:0 8px;">›</span>
            <span>@Model.PetName</span>
        </nav>

        <div class="pet-details-inner">
            <!-- Main Content -->
            <div class="pet-details-main">

                <!-- Pet Image -->
                <div class="pet-details-img-card">
                    @if (!string.IsNullOrEmpty(Model.ImagePath))
                    {
                        <img src="@Model.ImagePath" alt="@Model.PetName" style="width:100%; height:auto; border-radius:24px; display:block;" />
                    }
                    else
                    {
                        <div class="pet-details-img">
                            @(Model.Species.SpeciesName.ToLower() switch
                            {
                                "dog" => "🐶",
                                "cat" => "🐱",
                                "rabbit" => "🐰",
                                "bird" => "🐦",
                                _ => "🐾"
                            })
                        </div>
                    }
                </div>

                <!-- Pet Info -->
                <div class="pet-details-info">
                    <div class="pet-details-header">
                        <div>
                            <h1 class="pet-details-name">@Model.PetName</h1>
                            <p class="pet-details-breed">@Model.Breed.BreedName</p>
                        </div>
                        <span class="pet-status-badge @Model.AdoptionStatus.StatusName.ToLower()" style="font-size:0.88rem; padding:8px 16px;">@Model.AdoptionStatus.StatusName</span>
                    </div>

                    <!-- Quick Stats -->
                    <div class="pet-stats-row">
                        <div class="pet-stat-card">
                            <div class="pet-stat-icon">📅</div>
                            <div class="pet-stat-label">Age</div>
                            <div class="pet-stat-value">@Model.Age</div>
                        </div>
                        <div class="pet-stat-card">
                            <div class="pet-stat-icon">🐕</div>
                            <div class="pet-stat-label">Breed</div>
                            <div class="pet-stat-value">@Model.Breed.BreedName</div>
                        </div>
                        <div class="pet-stat-card">
                            <div class="pet-stat-icon">⚧</div>
                            <div class="pet-stat-label">Gender</div>
                            <div class="pet-stat-value">@Model.Gender.GenderName</div>
                        </div>
                        <div class="pet-stat-card">
                            <div class="pet-stat-icon">💉</div>
                            <div class="pet-stat-label">Vaccinated</div>
                            <div class="pet-stat-value">@(Model.Vaccinated ? "Yes ✓" : "No ✗")</div>
                        </div>
                        <div class="pet-stat-card">
                            <div class="pet-stat-icon">📍</div>
                            <div class="pet-stat-label">Location</div>
                            <div class="pet-stat-value">@(string.IsNullOrEmpty(Model.PetOwner.FirstName) ? "Cebu City" : Model.PetOwner.FirstName)</div>
                        </div>
                        <div class="pet-stat-card">
                            <div class="pet-stat-icon">🐾</div>
                            <div class="pet-stat-label">Type</div>
                            <div class="pet-stat-value">@Model.Species.SpeciesName</div>
                        </div>
                    </div>

                    <!-- Description -->
                    <h3 style="margin-bottom:12px; font-size:1.05rem;">About @Model.PetName</h3>
                    <p class="pet-description">
                        @(string.IsNullOrEmpty(Model.Description) ? $"Meet {Model.PetName}, a lovely {Model.Breed.BreedName} looking for a forever home!" : Model.Description)
                    </p>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="pet-details-sidebar">

                <!-- Interested in Adopting? -->
                <div class="sidebar-card" style="border: 2px solid var(--green-light); position: relative;">
                    <h3 class="sidebar-card-title" style="color:var(--orange-accent); margin-bottom: 15px;">Interested in Adopting?</h3>

                    <div style="display: flex; gap: 15px; margin-bottom: 20px;">
                        <div style="width: 80px; height: 80px; border-radius: 20px; background: var(--green-pale); flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; overflow: hidden;">
                             @if (!string.IsNullOrEmpty(Model.ImagePath))
                             {
                                 <img src="@Model.ImagePath" style="width:100%; height:100%; object-fit:cover;" />
                             }
                             else
                             {
                                 @(Model.Species.SpeciesName.ToLower() switch { "dog" => "🐶", "cat" => "🐱", "rabbit" => "🐰", "bird" => "🐦", _ => "🐾" })
                             }
                        </div>
                        <div>
                            <div style="font-weight: 800; font-size: 1.1rem; color: var(--text-dark); margin-bottom: 2px;">@Model.PetName</div>
                            <div style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 8px;">Looking for a home</div>
                            <div style="font-size: 0.75rem; color: var(--text-muted); line-height: 1.4;">
                                Age: @Model.Age<br>
                                Gender: @Model.Gender.GenderName<br>
                                Breed: @Model.Breed.BreedName<br>
                                Vaccinated: @(Model.Vaccinated ? "Yes" : "No")
                            </div>
                        </div>
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 15px;">
                        <div style="background: #dcfce7; color: #166534; padding: 10px 5px; border-radius: 12px; font-weight: 700; font-size: 0.75rem; text-align: center;">
                            @Model.PetOwner.PhoneNumber
                        </div>
                        <div style="background: #fef9c3; color: #854d0e; padding: 10px 5px; border-radius: 12px; font-weight: 700; font-size: 0.75rem; text-align: center;">
                            @(string.IsNullOrEmpty(Model.PetOwner.FirstName) ? "Cebu City" : Model.PetOwner.FirstName)
                        </div>
                    </div>
                    
                    <a href="tel:@Model.PetOwner.PhoneNumber" class="btn btn-green" style="width:100%; font-size: 0.9rem;">Contact Owner</a>
                </div>

                <!-- Pet Details Card -->
                <div class="sidebar-card">
                    <h3 class="sidebar-card-title">Pet Details</h3>
                    <div style="display:flex; flex-direction:column; gap:10px;">
                        <div style="display:flex; justify-content:space-between; align-items:center; padding:8px 0; border-bottom:1px solid var(--green-light); font-size:0.88rem;">
                            <span style="color:var(--text-muted);">🐾 Name</span>
                            <span style="font-weight:600; color:var(--text-dark);">@Model.PetName</span>
                        </div>
                        <div style="display:flex; justify-content:space-between; align-items:center; padding:8px 0; border-bottom:1px solid var(--green-light); font-size:0.88rem;">
                            <span style="color:var(--text-muted);">🐕 Type</span>
                            <span style="font-weight:600; color:var(--text-dark);">@Model.Species.SpeciesName</span>
                        </div>
                        <div style="display:flex; justify-content:space-between; align-items:center; padding:8px 0; border-bottom:1px solid var(--green-light); font-size:0.88rem;">
                            <span style="color:var(--text-muted);">🦮 Breed</span>
                            <span style="font-weight:600; color:var(--text-dark);">@Model.Breed.BreedName</span>
                        </div>
                        <div style="display:flex; justify-content:space-between; align-items:center; padding:8px 0; border-bottom:1px solid var(--green-light); font-size:0.88rem;">
                            <span style="color:var(--text-muted);">📅 Age</span>
                            <span style="font-weight:600; color:var(--text-dark);">@Model.Age</span>
                        </div>
                        <div style="display:flex; justify-content:space-between; align-items:center; padding:8px 0; border-bottom:1px solid var(--green-light); font-size:0.88rem;">
                            <span style="color:var(--text-muted);">♂ Gender</span>
                            <span style="font-weight:600; color:var(--text-dark);">@Model.Gender.GenderName</span>
                        </div>
                        <div style="display:flex; justify-content:space-between; align-items:center; padding:8px 0; border-bottom:1px solid var(--green-light); font-size:0.88rem;">
                            <span style="color:var(--text-muted);">💉 Vaccinated</span>
                            <span style="font-weight:600; color:var(--text-dark);">@(Model.Vaccinated ? "Yes" : "No")</span>
                        </div>
                        <div style="display:flex; justify-content:space-between; align-items:center; padding:8px 0; border-bottom:1px solid var(--green-light); font-size:0.88rem;">
                            <span style="color:var(--text-muted);">📍 Location</span>
                            <span style="font-weight:600; color:var(--text-dark);">@(string.IsNullOrEmpty(Model.PetOwner.FirstName) ? "Cebu City" : Model.PetOwner.FirstName)</span>
                        </div>
                    </div>
                </div>

            </div><!-- /.sidebar -->
        </div>
    </div>
</div>
