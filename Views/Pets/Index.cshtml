@model IEnumerable<FureverHome.Models.Pet>
@{
    ViewData["Title"] = "Pets Looking for a Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="/css/pets.css" />
}

<div class="pets-page">
    <div class="container">
        <!-- Header -->
        <div class="pets-header">
            <span class="section-eyebrow">Find Your Match</span>
            <h1>Pets Looking for a <span class="highlight">Home</span></h1>
            <p>Browse all available pets and find your perfect companion. All pets deserve a loving home.</p>
        </div>

        <!-- Filter Pills -->
        <div class="filter-bar">
            <button class="filter-pill active" data-filter="all">All Pets</button>
            <button class="filter-pill" data-filter="dog">🐕 Dogs</button>
            <button class="filter-pill" data-filter="cat">🐈 Cats</button>
            <button class="filter-pill" data-filter="rabbit">🐇 Rabbits</button>
            <button class="filter-pill" data-filter="bird">🐦 Birds</button>
            <button class="filter-pill" data-filter="other">🐾 Others</button>
        </div>

        <!-- Pets Grid -->
        <div class="pets-grid">

            @foreach (var pet in Model)
            {
                <div class="pet-listing-card" data-type="@pet.Species.SpeciesName.ToLower()">
                    <div class="pet-img-wrap">
                        @if (!string.IsNullOrEmpty(pet.ImagePath))
                        {
                            <img src="@pet.ImagePath" alt="@pet.PetName" style="width:100%; height:100%; object-fit:cover;" />
                        }
                        else
                        {
                            <div class="pet-img-placeholder">
                                @(pet.Species.SpeciesName.ToLower() switch
                                {
                                    "dog" => "🐶",
                                    "cat" => "🐱",
                                    "rabbit" => "🐰",
                                    "bird" => "🐦",
                                    _ => "🐾"
                                })
                            </div>
                        }
                        <span class="pet-status-badge @pet.AdoptionStatus.StatusName.ToLower()">@pet.AdoptionStatus.StatusName</span>
                        <button class="pet-save-btn" title="Save to favorites">❤</button>
                    </div>
                    <div class="pet-listing-body">
                        <div class="pet-listing-name">@pet.PetName</div>
                        <div class="pet-listing-meta">
                            <span class="meta-chip">@(pet.Species.SpeciesName.ToLower() == "dog" ? "🐕" : pet.Species.SpeciesName.ToLower() == "cat" ? "🐈" : "🐾") @pet.Breed.BreedName</span>
                            <span class="meta-chip">📅 @pet.Age</span>
                            <span class="meta-chip">@(pet.Gender.GenderName.ToLower() == "male" ? "♂" : "♀") @pet.Gender.GenderName</span>
                        </div>
                        <div class="pet-location">📍 @(string.IsNullOrEmpty(pet.Address) ? "Cebu City" : pet.Address)</div>
                        <div class="pet-listing-actions">
                            <a href="/Pets/Details/@pet.PetID" class="btn btn-green btn-sm">Learn More</a>
                        </div>
                    </div>
                </div>
            }

            @if (!Model.Any())
            {
                <div class="no-pets-message" style="grid-column: 1 / -1; text-align: center; padding: 40px;">
                    <h3>No pets found yet. 🐾</h3>
                    <p>Be the first to list a pet for adoption!</p>
                    <a href="/Dashboard/Create" class="btn btn-green">List a Pet</a>
                </div>
            }

        </div><!-- /.pets-grid -->

    </div><!-- /.container -->
</div>

@section Scripts {
<script>
    // Save toggle functionality
    document.querySelectorAll('.pet-save-btn').forEach(btn => {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            this.classList.toggle('active');
            
            // Optional: Add a little animation or toast
            if (this.classList.contains('active')) {
                this.innerHTML = '❤️';
            } else {
                this.innerHTML = '❤';
            }
        });
    });

    // Filter functionality
    document.querySelectorAll('.filter-pill').forEach(pill => {
        pill.addEventListener('click', function() {
            // Remove active class from all pills
            document.querySelectorAll('.filter-pill').forEach(p => p.classList.remove('active'));
            // Add active class to clicked pill
            this.classList.add('active');

            const filter = this.dataset.filter;
            document.querySelectorAll('.pet-listing-card').forEach(card => {
                if (filter === 'all' || card.dataset.type === filter) {
                    card.style.display = 'flex';
                } else {
                    card.style.display = 'none';
                }
            });
        });
    });
</script>
}
