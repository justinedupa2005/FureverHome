@model ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="/css/profile.css" />
}

<div class="profile-page">
    <div class="container">
        <div class="profile-inner">

            <!-- Sidebar -->
            <div class="profile-sidebar">
                <div class="profile-avatar-wrap">
                    <div class="profile-avatar">
                        <img src="~/images/profile_icon.png" alt="Profile Icon" style="mix-blend-mode: multiply;" />
                    </div>
                    <button class="avatar-edit-btn" title="Change photo">✎</button>
                </div>
                <div class="profile-name">@Model.FullName</div>
                <div class="profile-email">@Model.Email</div>

                <div class="profile-mini-stats">
                    <div class="profile-mini-stat">
                        <div class="profile-mini-stat-number">3</div>
                        <div class="profile-mini-stat-label">Listings</div>
                    </div>
                    <div class="profile-mini-stat">
                        <div class="profile-mini-stat-number">2</div>
                        <div class="profile-mini-stat-label">Adopted</div>
                    </div>
                </div>
            </div>

            <!-- Profile Form -->
            <div class="profile-form-card">
                <div class="profile-form-header">
                    <h2>Profile <span class="text-green">Information</span></h2>
                    <p>Update your personal details and contact information.</p>
                </div>

                <form asp-action="Update" asp-controller="Profile" method="post" id="profileForm">
                    @Html.AntiForgeryToken()

                    <!-- View Mode Fields -->
                    <div id="viewMode">
                        <div class="profile-field">
                            <div class="profile-field-label">Name</div>
                            <div class="profile-field-value">@Model.FullName</div>
                        </div>
                        <div class="profile-field">
                            <div class="profile-field-label">Email Address</div>
                            <div class="profile-field-value">@Model.Email</div>
                        </div>
                        <div class="profile-field">
                            <div class="profile-field-label">Phone Number</div>
                            <div class="profile-field-value">@Model.PhoneNumber</div>
                        </div>
                        <div class="profile-field">
                            <div class="profile-field-label">Address</div>
                            <div class="profile-field-value">@Model.Address</div>
                        </div>

                        <div class="profile-actions">
                            <button type="button" class="btn btn-green" onclick="toggleEdit(true)">
                                ✏️ Edit Profile
                            </button>
                        </div>
                    </div>

                    <!-- Edit Mode Fields -->
                    <div id="editMode" style="display:none;">
                        <div class="form-group">
                            <label class="form-label">First Name</label>
                            <input type="text" name="FirstName" value="@Model.FirstName" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Last Name</label>
                            <input type="text" name="LastName" value="@Model.LastName" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Email Address</label>
                            <input type="email" name="Email" value="@Model.Email" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Phone Number</label>
                            <input type="tel" name="PhoneNumber" value="@Model.PhoneNumber" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Address</label>
                            <input type="text" name="Address" value="@Model.Address" class="form-control" />
                        </div>

                        <div class="profile-actions">
                            <button type="button" class="btn btn-outline-green" onclick="toggleEdit(false)">Cancel</button>
                            <button type="submit" class="btn btn-green">Save Changes ✓</button>
                        </div>
                    </div>

                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleEdit(editing) {
            document.getElementById('viewMode').style.display = editing ? 'none' : 'block';
            document.getElementById('editMode').style.display = editing ? 'block' : 'none';
        }
    </script>
}