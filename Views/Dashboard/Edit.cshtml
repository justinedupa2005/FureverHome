@model FureverHome.Models.Pet
@{
    ViewData["Title"] = "Edit Listing";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="/css/dashboard.css" />
}

<div class="form-page">
    <div class="container">
        <div class="form-card" style="position:relative;">

            <!-- Close / Back -->
            <a href="/Dashboard" class="modal-close" title="Back to Dashboard">✕</a>

            <div class="section-eyebrow" style="text-align:center; margin-bottom:8px;">EDIT LISTING</div>
            <h1 class="form-page-title">Edit <span class="highlight">Listing</span></h1>
            <p class="form-page-subtitle">Update your pet's information below.</p>

            <form asp-action="Edit" asp-controller="Dashboard" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.PetID" />

                <!-- Current Image Preview -->
                <div class="form-group">
                    <label class="form-label">Current Photo</label>
                    @if (!string.IsNullOrEmpty(Model.ImagePath))
                    {
                        <div class="image-preview-placeholder" id="previewWrap" style="padding:0; overflow:hidden;">
                            <img src="@Model.ImagePath" alt="@Model.PetName" style="width:100%; height:100%; object-fit:cover;" />
                        </div>
                    }
                    else
                    {
                        <div class="image-preview-placeholder" id="previewWrap">
                            @(Model.Species.SpeciesName.ToLower() switch { "dog" => "🐶", "cat" => "🐱", "rabbit" => "🐰", "bird" => "🐦", _ => "🐾" })
                        </div>
                    }
                </div>

                <!-- Pet Name -->
                <div class="form-group">
                    <label class="form-label">Pet Name *</label>
                    <input type="text" name="Name" value="@Model.PetName" class="form-control" required />
                </div>

                <div class="form-two-col">
                    <!-- Type -->
                    <div class="form-group">
                        <label class="form-label">Type *</label>
                        <select name="Type" class="form-control" required>
                            <option value="dog" selected="@(Model.Species.SpeciesName.ToLower() == "dog")">🐕 Dog</option>
                            <option value="cat" selected="@(Model.Species.SpeciesName.ToLower() == "cat")">🐈 Cat</option>
                            <option value="rabbit" selected="@(Model.Species.SpeciesName.ToLower() == "rabbit")">🐇 Rabbit</option>
                            <option value="bird" selected="@(Model.Species.SpeciesName.ToLower() == "bird")">🐦 Bird</option>
                            <option value="other" selected="@(Model.Species.SpeciesName.ToLower() == "other")">🐾 Other</option>
                        </select>
                    </div>

                    <!-- Breed -->
                    <div class="form-group">
                        <label class="form-label">Breed *</label>
                        <input type="text" name="Breed" value="@Model.Breed.BreedName" class="form-control" required />
                    </div>
                </div>

                <div class="form-two-col">
                    <!-- Age -->
                    <div class="form-group">
                        <label class="form-label">Age *</label>
                        <input type="text" name="Age" value="@Model.Age" class="form-control" required />
                    </div>

                    <!-- Gender -->
                    <div class="form-group">
                        <label class="form-label">Gender *</label>
                        <select name="Gender" class="form-control" required>
                            <option value="male" selected="@(Model.Gender.GenderName.ToLower() == "male")">♂ Male</option>
                            <option value="female" selected="@(Model.Gender.GenderName.ToLower() == "female")">♀ Female</option>
                        </select>
                    </div>
                </div>

                <!-- Contact Number -->
                <div class="form-group">
                    <label class="form-label">Contact Number *</label>
                    <input type="tel" name="ContactNumber" value="@Model.PetOwner.PhoneNumber" class="form-control" required />
                </div>

                <!-- Vaccinated -->
                <div class="form-group">
                    <label class="form-label">Vaccinated?</label>
                    <div class="radio-group">
                        <label class="radio-option">
                            <input type="radio" name="Vaccinated" value="yes" checked="@Model.Vaccinated" /> Yes
                        </label>
                        <label class="radio-option">
                            <input type="radio" name="Vaccinated" value="no" checked="@(!Model.Vaccinated)" /> No
                        </label>
                    </div>
                </div>

                <!-- Description -->
                <div class="form-group">
                    <label class="form-label">About this Pet</label>
                    <textarea name="Description" class="form-control" rows="4"
                              style="resize:vertical; min-height:100px;">@Model.Description</textarea>
                </div>

                <!-- New Photo -->
                <div class="form-group">
                    <label class="form-label">Update Photo (optional)</label>
                    <div class="upload-area">
                        <div class="upload-icon">📸</div>
                        <h4>Drag & Drop your photo here</h4>
                        <p>Leave empty to keep the current photo</p>
                        <button type="button" class="btn btn-outline-green btn-sm"
                                onclick="document.getElementById('petPhotoEdit').click()">
                            Select New Photo
                        </button>
                        <input type="file" id="petPhotoEdit" name="Photo" accept="image/*"
                               data-upload-preview="photoPreviewEdit" />
                    </div>
                    <img id="photoPreviewEdit" src="" alt="Preview"
                         style="display:none; width:100%; border-radius:16px; margin-top:8px; max-height:200px; object-fit:cover;" />
                </div>

                <!-- Actions -->
                <div class="form-actions">
                    <a href="/Dashboard/Delete/@Model.PetID" class="btn btn-danger"
                       onclick="return confirm('Delete this listing permanently?')">🗑️ Delete Listing</a>
                    <div style="display:flex; gap:10px; margin-left:auto;">
                        <a href="/Dashboard" class="btn btn-outline-green">Cancel</a>
                        <button type="submit" class="btn btn-green">Save Changes ✓</button>
                    </div>
                </div>

            </form>
        </div>
    </div>
</div>
