@{
    ViewData["Title"] = "My Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="/css/dashboard.css" />
}

<div class="dashboard-page">
    <div class="container">

        <!-- Dashboard Header -->
        <div class="dashboard-header">
            <div>
                <div class="section-eyebrow" style="text-align:left; margin-bottom:4px;">Welcome back!</div>
                <h1 class="dashboard-title">My Pet <span class="text-orange">Listing</span></h1>
                <p class="dashboard-subtitle">Manage your adoptable pets and track inquiries.</p>
            </div>
            <a href="/Dashboard/Create" class="btn btn-orange">+ Add New Pet</a>
        </div>

        <!-- Listings Grid -->
        <div class="dashboard-listings-grid">

            <!-- Dashboard Pet Card 1 -->
            <div class="dashboard-pet-card">
                <div class="dashboard-pet-img">🐶</div>
                <div class="dashboard-pet-body">
                    <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:8px;">
                        <div class="dashboard-pet-name">Buddy</div>
                        <span class="badge badge-green" style="font-size:0.72rem;">Available</span>
                    </div>
                    <div class="dashboard-pet-meta">
                        <span class="meta-chip">🐕 Labrador</span>
                        <span class="meta-chip">📅 3 yrs</span>
                        <span class="meta-chip">♂ Male</span>
                    </div>
                    <div class="dashboard-pet-actions">
                        <a href="/Dashboard/Edit/1" class="btn btn-outline-green">✏️ Edit</a>
                        <a href="/Dashboard/Delete/1" class="btn btn-danger"
                           onclick="return confirm('Are you sure you want to delete this listing?')">🗑️ Delete</a>
                    </div>
                </div>
            </div>

            <!-- Dashboard Pet Card 2 -->
            <div class="dashboard-pet-card">
                <div class="dashboard-pet-img">🐱</div>
                <div class="dashboard-pet-body">
                    <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:8px;">
                        <div class="dashboard-pet-name">Mochi</div>
                        <span class="badge badge-orange" style="font-size:0.72rem;">Pending</span>
                    </div>
                    <div class="dashboard-pet-meta">
                        <span class="meta-chip">🐈 Shorthair</span>
                        <span class="meta-chip">📅 2 yrs</span>
                        <span class="meta-chip">♀ Female</span>
                    </div>
                    <div class="dashboard-pet-actions">
                        <a href="/Dashboard/Edit/2" class="btn btn-outline-green">✏️ Edit</a>
                        <a href="/Dashboard/Delete/2" class="btn btn-danger"
                           onclick="return confirm('Are you sure you want to delete this listing?')">🗑️ Delete</a>
                    </div>
                </div>
            </div>

            <!-- Dashboard Pet Card 3 -->
            <div class="dashboard-pet-card">
                <div class="dashboard-pet-img">🐰</div>
                <div class="dashboard-pet-body">
                    <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:8px;">
                        <div class="dashboard-pet-name">Kiwi</div>
                        <span class="badge badge-green" style="font-size:0.72rem;">Available</span>
                    </div>
                    <div class="dashboard-pet-meta">
                        <span class="meta-chip">🐇 Rabbit</span>
                        <span class="meta-chip">📅 1 yr</span>
                        <span class="meta-chip">♂ Male</span>
                    </div>
                    <div class="dashboard-pet-actions">
                        <a href="/Dashboard/Edit/3" class="btn btn-outline-green">✏️ Edit</a>
                        <a href="/Dashboard/Delete/3" class="btn btn-danger"
                           onclick="return confirm('Are you sure you want to delete this listing?')">🗑️ Delete</a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
