@model IEnumerable<FureverHome.Models.Pet>
@{
    ViewData["Title"] = "My Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="/css/dashboard.css" />
}

<div class="dashboard-page">
    <div class="container">

        <!-- Dashboard Header -->
        <div class="dashboard-header">
            <div>
                <div class="section-eyebrow" style="text-align:left; margin-bottom:4px;">Welcome back!</div>
                <h1 class="dashboard-title">My Pet <span class="text-orange">Listing</span></h1>
                <p class="dashboard-subtitle">Manage your adoptable pets and track inquiries.</p>
            </div>
            <a href="/Dashboard/Create" class="btn btn-orange">+ Add New Pet</a>
        </div>

        <!-- Listings Grid -->
        <div class="dashboard-listings-grid">

            @foreach (var pet in Model)
            {
                <div class="dashboard-pet-card">
                    @if (!string.IsNullOrEmpty(pet.ImagePath))
                    {
                        <div class="dashboard-pet-img" style="padding:0;">
                            <img src="@pet.ImagePath" alt="@pet.PetName" style="width:100%; height:100%; object-fit:cover; border-radius:12px;" />
                        </div>
                    }
                    else
                    {
                        <div class="dashboard-pet-img">
                            @(pet.Species.SpeciesName.ToLower() switch
                            {
                                "dog" => "🐶",
                                "cat" => "🐱",
                                "rabbit" => "🐰",
                                "bird" => "🐦",
                                _ => "🐾"
                            })
                        </div>
                    }
                    <div class="dashboard-pet-body">
                        <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:8px;">
                            <div class="dashboard-pet-name">@pet.PetName</div>
                            <span class="badge @(pet.AdoptionStatus.StatusName.ToLower() == "available" ? "badge-green" : "badge-orange")" style="font-size:0.72rem;">@pet.AdoptionStatus.StatusName</span>
                        </div>
                        <div class="dashboard-pet-meta">
                            <span class="meta-chip">@(pet.Species.SpeciesName.ToLower() == "dog" ? "🐕" : pet.Species.SpeciesName.ToLower() == "cat" ? "🐈" : "🐾") @pet.Breed.BreedName</span>
                            <span class="meta-chip">📅 @pet.Age</span>
                            <span class="meta-chip">@(pet.Gender.GenderName.ToLower() == "male" ? "♂" : "♀") @pet.Gender.GenderName</span>
                        </div>

                        <div class="pet-location" style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 12px;">
                            📍 @(string.IsNullOrEmpty(pet.Address) ? "Cebu City" : pet.Address)
                        </div>

                        <div class="dashboard-pet-actions">
                            <a href="/Dashboard/Edit/@pet.PetID" class="btn btn-outline-green">✏️ Edit</a>
                            <a href="/Dashboard/Delete/@pet.PetID" class="btn btn-danger"
                               onclick="return confirm('Are you sure you want to delete this listing?')">🗑️ Delete</a>
                        </div>
                    </div>
                </div>
            }

            @if (!Model.Any())
            {
                <div class="no-listings-message" style="grid-column: 1 / -1; text-align: center; padding: 40px; background: #fff; border-radius: 16px; border: 2px dashed #ddd;">
                    <h3>You haven't listed any pets yet. 🐾</h3>
                    <p>Click the button above to start helping pets find their forever home.</p>
                </div>
            }

        </div>
    </div>
</div>
