@model IEnumerable<FureverHome.Models.Pet>
@{
    ViewData["Title"] = "My Favorite Pets";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="/css/pets.css" />
    <style>
        .no-favorites {
            text-align: center;
            padding: 80px 20px;
            background: white;
            border-radius: var(--radius-card);
            box-shadow: var(--shadow-card);
            grid-column: 1 / -1;
        }
        .no-favorites-icon {
            font-size: 4rem;
            margin-bottom: 20px;
            display: block;
        }
        .no-favorites h2 {
            margin-bottom: 12px;
            color: var(--text-dark);
        }
        .no-favorites p {
            color: var(--text-muted);
            margin-bottom: 30px;
            max-width: 400px;
            margin-left: auto;
            margin-right: auto;
        }
    </style>
}

<div class="pets-page">
    <div class="container">
        <!-- Header -->
        <div class="pets-header">
            <span class="section-eyebrow">Your Favorites</span>
            <h1>Saved <span class="highlight">Pets</span></h1>
            <p>These are the pets you've favorited. Keep track of your future companions here.</p>
        </div>

        @Html.AntiForgeryToken()

        <!-- Pets Grid -->
        <div class="pets-grid">

            @foreach (var pet in Model)
            {
                <div class="pet-listing-card" data-type="@pet.Species.SpeciesName.ToLower()">
                    <div class="pet-img-wrap">
                        @if (!string.IsNullOrEmpty(pet.ImagePath))
                        {
                            <img src="@pet.ImagePath" alt="@pet.PetName" style="width:100%; height:100%; object-fit:cover;" />
                        }
                        else
                        {
                            <div class="pet-img-placeholder">
                                @(pet.Species.SpeciesName.ToLower() switch
                                {
                                    "dog" => "🐶",
                                    "cat" => "🐱",
                                    "rabbit" => "🐰",
                                    "bird" => "🐦",
                                    _ => "🐾"
                                })
                            </div>
                        }
                        <span class="pet-status-badge @pet.AdoptionStatus.StatusName.ToLower()">@pet.AdoptionStatus.StatusName</span>
                        <button class="pet-save-btn active" data-id="@pet.PetID" title="Remove from favorites">❤️</button>
                    </div>
                    <div class="pet-listing-body">
                        <div class="pet-listing-name">@pet.PetName</div>
                        <div class="pet-listing-meta">
                            <span class="meta-chip">@(pet.Species.SpeciesName.ToLower() == "dog" ? "🐕" : pet.Species.SpeciesName.ToLower() == "cat" ? "🐈" : "🐾") @pet.Breed.BreedName</span>
                            <span class="meta-chip">📅 @pet.Age</span>
                            <span class="meta-chip">@(pet.Gender.GenderName.ToLower() == "male" ? "♂" : "♀") @pet.Gender.GenderName</span>
                        </div>
                        <div class="pet-location">📍 @(string.IsNullOrEmpty(pet.Address) ? "Cebu City" : pet.Address)</div>
                        <div class="pet-listing-actions">
                            <a href="/Pets/Details/@pet.PetID" class="btn btn-green btn-sm">Learn More</a>
                        </div>
                    </div>
                </div>
            }

            @if (!Model.Any())
            {
                <div class="no-favorites">
                    <span class="no-favorites-icon">❤️</span>
                    <h2>No favorites yet</h2>
                    <p>You haven't saved any pets to your favorites yet. Start browsing to find your match!</p>
                    <a href="/Pets" class="btn btn-green">Browse All Pets</a>
                </div>
            }

        </div><!-- /.pets-grid -->

    </div><!-- /.container -->
</div>

@section Scripts {
<script>
    // Toggle favorite functionality
    document.querySelectorAll('.pet-save-btn').forEach(btn => {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            const petId = this.dataset.id;
            const card = this.closest('.pet-listing-card');
            
            fetch('/Favorites/Toggle', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: `petId=${petId}`
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    if (!data.isFavorite) {
                        // In favorites page, removing should probably hide the card
                        card.style.transition = 'all 0.3s ease';
                        card.style.opacity = '0';
                        card.style.transform = 'scale(0.9)';
                        setTimeout(() => {
                            card.remove();
                            if (document.querySelectorAll('.pet-listing-card').length === 0) {
                                location.reload(); // Show the empty state
                            }
                        }, 300);
                    }
                }
            });
        });
    });
</script>
}
