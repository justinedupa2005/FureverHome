@model LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="/css/auth.css" />
}

<div class="auth-page">
    <div class="auth-card">
        <!-- Mascot (login_icon.png) -->
        <div class="auth-mascot">
            <div class="mascot-bg">
                <img src="~/images/login_icon.png" alt="Login Mascot" style="width: 80%; mix-blend-mode: multiply;" />
            </div>
        </div>

        <h1 class="auth-title">Welcome Back!</h1>
        <p class="auth-subtitle">Login to find your furever companion 🐾</p>

        <form id="loginForm" asp-action="Login" asp-controller="Account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Email" class="form-label"></label>
                <div class="input-icon-wrap">
                    <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                    <span class="input-icon">✉️</span>
                </div>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password" class="form-label"></label>
                <div class="input-icon-wrap">
                    <input asp-for="Password" class="form-control" placeholder="••••••••" />
                    <span class="input-icon" data-toggle-password="Password" style="cursor:pointer;">👁️</span>
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="auth-extras">
                <label class="checkbox-wrap">
                    <input asp-for="RememberMe" />
                    <span>@Html.DisplayNameFor(m => m.RememberMe)</span>
                </label>
                <a href="/Account/ForgotPassword" class="forgot-link">Forgot Password?</a>
            </div>

            <button type="submit" class="btn btn-green auth-btn">Login</button>
        </form>

        <p class="auth-footer">
            Don't have an account? <a href="/Account/Register">Sign Up for Free</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/auth-ajax.js"></script>
}
