@model RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="/css/auth.css" />
}

<div class="auth-page">
    <div class="auth-card register-card">
        <!-- Mascot (sign_up_icon.png) -->
        <div class="auth-mascot">
            <div class="mascot-bg">
                <img src="~/images/sign_up_icon.png" alt="Sign Up Mascot" style="width: 80%; mix-blend-mode: multiply;" />
            </div>
        </div>

        <h1 class="auth-title">Join Furever Home</h1>
        <p class="auth-subtitle">Create your free account and start your adoption journey 🏠</p>

        <form id="registerForm" asp-action="Register" asp-controller="Account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="FirstName" class="form-label"></label>
                    <input asp-for="FirstName" class="form-control" placeholder="Juan" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="LastName" class="form-label"></label>
                    <input asp-for="LastName" class="form-control" placeholder="dela Cruz" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Email" class="form-label"></label>
                <div class="input-icon-wrap">
                    <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                    <span class="input-icon">✉️</span>
                </div>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="PhoneNumber" class="form-label"></label>
                <div class="input-icon-wrap">
                    <input asp-for="PhoneNumber" class="form-control" placeholder="+63 9XX XXX XXXX" />
                    <span class="input-icon">📞</span>
                </div>
                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password" class="form-label"></label>
                <div class="input-icon-wrap">
                    <input asp-for="Password" class="form-control" placeholder="Min. 6 characters" />
                    <span class="input-icon" data-toggle-password="Password" style="cursor:pointer;">👁️</span>
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <div class="input-icon-wrap">
                    <input asp-for="ConfirmPassword" class="form-control" placeholder="Repeat your password" />
                    <span class="input-icon" data-toggle-password="ConfirmPassword" style="cursor:pointer;">👁️</span>
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-green auth-btn">Create Account</button>
        </form>

        <p class="auth-footer">
            Already have an account? <a href="/Account/Login">Login</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/auth-ajax.js"></script>
}
